rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: voices
    // Document ID: voiceId
    // Fields:
    //   - id: string (required) - unique identifier
    //   - name: string (required, size < 50) - display name
    //   - avatar: string (required, isValidUrl) - avatar URL
    //   - description: string (optional, size < 200) - voice description
    //   - tags: list (optional, size < 10) - list of tags
    //   - isPublic: bool (optional) - visibility
    //   - creatorId: string (required) - UID of creator
    //   - createdAt: timestamp (required) - creation time
    //
    // Collection: songs
    // Document ID: songId
    // Fields:
    //   - id: string (required) - unique identifier
    //   - title: string (required, size < 100) - song title
    //   - artist: string (required, size < 100) - original artist
    //   - thumbnail: string (required, isValidUrl) - thumbnail URL
    //   - audioUrl: string (required, isValidUrl) - audio URL
    //   - userId: string (required) - UID of user who uploaded
    //   - createdAt: timestamp (required) - upload time
    //
    // Collection: covers
    // Document ID: coverId
    // Fields:
    //   - id: string (required) - unique identifier
    //   - title: string (required, size < 100) - cover title
    //   - artist: string (required, size < 100) - original artist
    //   - thumbnail: string (required, isValidUrl) - thumbnail URL
    //   - audioUrl: string (required, isValidUrl) - audio URL
    //   - voiceId: string (required) - ID of voice used
    //   - voiceName: string (required) - Name of voice used
    //   - userId: string (required) - UID of user who generated
    //   - createdAt: timestamp (required) - generation time
    //
    // Collection: jobs
    // Document ID: jobId
    // Fields:
    //   - id: string (required) - unique identifier
    //   - type: string (required, enum: download, separation, training, conversion) - job type
    //   - status: string (required, enum: pending, processing, completed, failed) - job status
    //   - progress: number (required, range: 0-100) - progress percentage
    //   - message: string (optional, size < 500) - status message
    //   - targetId: string (optional) - ID of target resource
    //   - userId: string (required) - UID of user who initiated
    //   - createdAt: timestamp (required) - creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "andrepopov28@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidVoice(data) {
      return hasRequiredFields(['id', 'name', 'avatar', 'creatorId', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'avatar', 'description', 'tags', 'isPublic', 'creatorId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             isValidUrl(data.avatar) &&
             (data.description == null || (data.description is string && data.description.size() < 200)) &&
             (data.tags == null || (data.tags is list && data.tags.size() < 10)) &&
             data.creatorId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidSong(data) {
      return hasRequiredFields(['id', 'title', 'artist', 'thumbnail', 'audioUrl', 'userId', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'title', 'artist', 'thumbnail', 'audioUrl', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.artist is string && data.artist.size() > 0 && data.artist.size() < 100 &&
             isValidUrl(data.thumbnail) &&
             isValidUrl(data.audioUrl) &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidCover(data) {
      return hasRequiredFields(['id', 'title', 'artist', 'thumbnail', 'audioUrl', 'voiceId', 'voiceName', 'userId', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'title', 'artist', 'thumbnail', 'audioUrl', 'voiceId', 'voiceName', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.artist is string && data.artist.size() > 0 && data.artist.size() < 100 &&
             isValidUrl(data.thumbnail) &&
             isValidUrl(data.audioUrl) &&
             data.voiceId is string &&
             data.voiceName is string &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidJob(data) {
      return hasRequiredFields(['id', 'type', 'status', 'progress', 'userId', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'type', 'status', 'progress', 'message', 'targetId', 'userId', 'createdAt']) &&
             data.type in ['download', 'separation', 'training', 'conversion'] &&
             data.status in ['pending', 'processing', 'completed', 'failed'] &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             (data.message == null || (data.message is string && data.message.size() < 500)) &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'client';
      allow update: if isAuthenticated() && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /voices/{voiceId} {
      allow read: if isAuthenticated() && (resource.data.get('isPublic', false) == true || resource.data.creatorId == request.auth.uid);
      allow create: if isAuthenticated() && isValidVoice(request.resource.data);
      allow update: if isAuthenticated() && resource.data.creatorId == request.auth.uid && isValidVoice(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    match /songs/{songId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSong(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidSong(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /covers/{coverId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidCover(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidCover(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidJob(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
